<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.OrderLineController" spacing="10" padding="10">

    <Label text="Add Order Line"/>

    <HBox spacing="5">
        <Label text="ID:"/>
        <TextField fx:id="idField" prefWidth="100"/>
    </HBox>

    <HBox spacing="5">
        <Label text="Product Name:"/>
        <TextField fx:id="productNameField" prefWidth="150"/>
    </HBox>

    <HBox spacing="5">
        <Label text="Quantity:"/>
        <TextField fx:id="quantityField" prefWidth="50"/>
    </HBox>

    <HBox spacing="5">
        <Label text="Price:"/>
        <TextField fx:id="priceField" prefWidth="80"/>
    </HBox>

    <Button text="Calculate Total" onAction="#calculateTotal"/>
    <Label fx:id="totalLabel"/>
</VBox>
