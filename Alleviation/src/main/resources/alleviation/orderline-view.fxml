<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" style="-fx-background-color: f1deff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="OrderLine">


    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Order Line Management" />

    <HBox alignment="CENTER" spacing="10">
        <TextField fx:id="productNameField" promptText="Product Name" />
        <TextField fx:id="quantityField" promptText="Quantity" />
        <TextField fx:id="priceField" promptText="Price" />
        <Button onAction="#addOrderLine" style="-fx-background-color: D3D3FF;" text="Add" />
        <Button onAction="#deleteOrderLine" style="-fx-background-color: D3D3FF;" text="Delete" />
    </HBox>

    <TableView fx:id="orderTable" prefHeight="300" prefWidth="500" style="-fx-background-color: D3D3FF;">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="100" style="-fx-background-color: D3D3FF;" text="ID" />
            <TableColumn fx:id="productColumn" prefWidth="150" style="-fx-background-color: D3D3FF;" text="Product" />
            <TableColumn fx:id="quantityColumn" prefWidth="100" style="-fx-background-color: D3D3FF;" text="Quantity" />
            <TableColumn fx:id="priceColumn" prefWidth="100" style="-fx-background-color: D3D3FF;" text="Price" />
         <TableColumn fx:id="idColumn1" prefWidth="125.0" style="-fx-background-color: D3D3FF;" />
        </columns>
    </TableView>

</VBox>
