<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="8" style="-fx-background-color: f1deff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="WishlistController">

    <Label text="Wishlist" />
   <AnchorPane prefHeight="21.0" prefWidth="500.0">
      <children>
         <Button layoutX="6.0" mnemonicParsing="false" onAction="#GotoBack" style="-fx-background-color: c7cbff;" text="Back" />
      </children>
   </AnchorPane>
    <TextField fx:id="productNameField" promptText="Product Name" />
    <TextField fx:id="descriptionField" promptText="Description" />

    <Button onAction="#addWishlist" style="-fx-background-color: c7cbff;" text="Add" />
    <Button onAction="#deleteWishlist" style="-fx-background-color: c7cbff;" text="Delete" />

    <TableView fx:id="wishlistTable" prefHeight="300" prefWidth="500" style="-fx-background-color: D3D3FF;">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="150" style="-fx-background-color: D3D3FF;" text="ID" />
            <TableColumn fx:id="productColumn" prefWidth="150" style="-fx-background-color: D3D3FF;" text="Product" />
            <TableColumn fx:id="descriptionColumn" prefWidth="200" style="-fx-background-color: D3D3FF;" text="Description" />
        </columns>
    </TableView>
</VBox>
